# KiroAware Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Optional: Custom data directory for KiroAware files
# Default: ~/.kiroaware/
# KIROAWARE_DATA_DIR=/path/to/custom/data

# Optional: Log level for MCP server
# Values: debug | info | warn | error
# Default: info
# KIROAWARE_LOG_LEVEL=info
